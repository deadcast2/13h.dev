{
  "name": "13h.dev",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A browser-based Turbo C++ 1.01 IDE for mode 13h VGA programming.",
  "license": "GPL-2.0-or-later",
  "author": "Caleb Cohoon",
  "scripts": {
    "predev": "npm run emulators:stage",
    "dev": "vite",
    "prebuild": "npm run emulators:stage",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "emulators:stage": "node tools/copy-emulator-assets.mjs"
  },
  "dependencies": {
    "7z-wasm": "^1.2.0",
    "emulators": "^8.4.1",
    "js-dos": "^8.4.1",
    "monaco-editor": "^0.52.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
