# Response headers for the production host.
#
# This format is read natively by Cloudflare Pages and by Netlify, so the same
# file works on either without translation. Vite copies public/ verbatim into
# dist/, which is what gets deployed.
#
# The first block is not optional. js-dos runs DOSBox in a worker and reaches
# for SharedArrayBuffer, which browsers only hand out to a cross-origin-isolated
# page. Without these two headers the app loads, renders the whole IDE, and then
# fails the moment anything tries to boot an emulator — so a build and a run
# break while setup, the editor and the file tree all look perfectly healthy.
# `vite.config.ts` sends the same pair to dev and preview; this is that same
# promise kept in production.
#
# require-corp additionally means every subresource must be same-origin (or
# carry CORP). Everything this app loads already is: Monaco's worker and its
# codicon font are bundled, and the DOSBox wasm is served from /emulators/.
# Adding a CDN script, a Google font or a remote image will be blocked outright.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Vite fingerprints everything under /assets/, so these are safe to keep forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The js-dos runtime is copied out of node_modules under its own plain name and
# is not fingerprinted, so it cannot be cached immutably — a bumped `emulators`
# version would otherwise be invisible to anyone who had already visited. A day
# is long enough to keep the 1.4 MB wasm out of a repeat visit's critical path.
/emulators/*
  Cache-Control: public, max-age=86400
